<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - GLMS.Web</title>

    <!-- Bootstrap -->
    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Site CSS -->
    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/GLMS.Web.styles.css"
          asp-append-version="true" />

    <!-- CUSTOM DASHBOARD STYLING -->
    <style>

            body {
                margin: 0;
                font-family: Arial, Helvetica, sans-serif;
                background-color: #f4f6f9;
            }

            /* SIDEBAR */
            .sidebar {
                position: fixed;
                top: 0;
                left: 0;
                width: 250px;
                height: 100vh;
                background-color: #1f2937;
                padding-top: 20px;
                overflow-y: auto;
            }

            .sidebar h2 {
                color: white;
                text-align: center;
                margin-bottom: 30px;
                font-weight: bold;
            }

            .sidebar a {
                display: block;
                color: #d1d5db;
                padding: 15px 25px;
                text-decoration: none;
                transition: 0.3s;
                font-size: 16px;
            }

            .sidebar a:hover {
                background-color: #374151;
                color: white;
                padding-left: 35px;
            }

            /* MAIN CONTENT */
            .main-content {
                margin-left: 250px;
                padding: 25px;
            }

            /* FOOTER */
            footer {
                margin-left: 250px;
                padding: 15px;
                background: white;
                border-top: 1px solid #ddd;
            }

            /* MOBILE RESPONSIVE */
            @@media (max-width: 768px) {

                .sidebar {
                    width: 100%;
                    height: auto;
                    position: relative;
                }

                .sidebar a {
                    text-align: center;
                    float: none;
                }

                .main-content {
                    margin-left: 0;
                }

                footer {
                    margin-left: 0;
                }
            }

    </style>

</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar">

        <h2>GLMS</h2>

        <a asp-controller="Dashboard"
               asp-action="Index">
            Dashboard
        </a>

        <a asp-controller="Client"
               asp-action="Index">
            Clients
        </a>

        <a asp-controller="Contract"
               asp-action="Index">
            Contracts
        </a>

        <a asp-controller="ServiceRequest"
               asp-action="Index">
            Service Requests
        </a>

        <a href="#">
            Reports
        </a>

    </div>

    <!-- MAIN PAGE CONTENT -->
    <div class="main-content">

        <main role="main" class="pb-3">

            @RenderBody()

        </main>

    </div>

    <!-- FOOTER -->
    <footer class="text-muted">

        <div class="container-fluid">

            &copy; 2026 - GLMS.Web |
            Global Logistics Management System

        </div>

    </footer>

    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"
            asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>