@model IEnumerable<ServiceRequest>

<h1>Service Requests</h1>

<a asp-action="Create" class="btn btn-primary">
    New Request
</a>

<br />
<br />

<table class="table table-striped">

    <thead>
        <tr>
            <th>ID</th>
            <th>Contract</th>
            <th>Description</th>
            <th>Cost (USD)</th>
            <th>Cost (ZAR)</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>

        @if (Model != null)
        {
            foreach (var item in Model)
            {
                <tr>

                    <td>@item.Id</td>

                    <td>@(item.Contract?.Client?.Name ?? "N/A")</td>

                    <td>@item.Description</td>

                    <td>@item.CostUSD</td>

                    <td>@item.CostZAR</td>

                    <td>
                        <span class="badge
                            @(item.Status == "Pending" ? "bg-warning" :
                                                            item.Status == "Approved" ? "bg-success" :
                                                            item.Status == "Completed" ? "bg-primary" :
                                                            "bg-secondary")">

                            @item.Status
                        </span>
                    </td>

                    <td>

                        <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-info btn-sm">
                            View
                        </a>

                        <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-danger btn-sm">
                            Delete
                        </a>

                    </td>

                </tr>
            }
        }

    </tbody>

</table>