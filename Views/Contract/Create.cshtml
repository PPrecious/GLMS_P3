@model Contract

<h1>Create Contract</h1>

<form asp-action="Create"
      method="post"
      enctype="multipart/form-data">

    <!-- CLIENT -->
    <div class="form-group mb-3">

        <label>Client</label>

        <select asp-for="ClientId"
                asp-items="ViewBag.Clients"
                class="form-control">
        </select>

    </div>

    <!-- START DATE -->
    <div class="form-group mb-3">

        <label>Start Date</label>

        <input asp-for="StartDate"
               type="date"
               class="form-control" />

    </div>

    <!-- END DATE -->
    <div class="form-group mb-3">

        <label>End Date</label>

        <input asp-for="EndDate"
               type="date"
               class="form-control" />

    </div>

    <!-- STATUS -->
    <div class="form-group mb-3">

        <label>Status</label>

        <select asp-for="Status"
                class="form-control">

            <option>Draft</option>
            <option>Active</option>
            <option>Expired</option>
            <option>On Hold</option>

        </select>

    </div>

    <!-- SERVICE LEVEL -->
    <div class="form-group mb-3">

        <label>Service Level</label>

        <select asp-for="ServiceLevel"
                asp-items="@(new SelectList(ViewBag.ServiceLevels))"
                class="form-control">
        </select>

    </div>

    <!-- PDF UPLOAD -->
    <div class="form-group mb-3">

        <label>Signed Agreement (PDF only)</label>

        <input type="file"
               name="file"
               accept=".pdf"
               class="form-control" />

        <small class="text-muted">
            Only PDF documents are allowed.
        </small>

    </div>

    <!-- BUTTON -->
    <button type="submit"
            class="btn btn-success">
        Save
    </button>

</form>